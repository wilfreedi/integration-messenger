APP_ENV=dev
APP_PORT=8080
APP_DEBUG=1
APP_BOOTSTRAP_DEMO_DATA=1
SITE_DOMAIN=localhost
ACME_EMAIL=admin@example.com

DB_HOST=postgres
DB_PORT=5432
DB_NAME=chat_sync
DB_USER=chat_sync
DB_PASSWORD=chat_sync

BITRIX_CONNECTOR_MODE=rest
BITRIX_WEBHOOK_TOKEN=
BITRIX_MANAGEMENT_TOKEN=
BITRIX_DEFAULT_CHANNEL_PROVIDER=telegram

TELEGRAM_CONNECTOR_MODE=stub
TELEGRAM_GATEWAY_BASE_URL=http://telegram-gateway:8090
TELEGRAM_GATEWAY_TOKEN=
PANEL_AUTH_PASSWORD=
PANEL_AUTH_SESSION_TTL_SECONDS=86400
PANEL_AUTH_MAX_ATTEMPTS=5
PANEL_AUTH_LOCK_SECONDS=900
PANEL_AUTH_BAN_SECONDS=315360000
PANEL_AUTH_PASSWORD_MAX_LENGTH=128
PANEL_AUTH_STATE_FILE=/tmp/chat-sync-panel-auth-state.json

TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_MANAGER_ACCOUNT_EXTERNAL_ID=telegram-manager-account
TELEGRAM_DEFAULT_CRM_PROVIDER=bitrix
TELEGRAM_GATEWAY_PORT=8090
TELEGRAM_GATEWAY_CORE_WEBHOOK_URL=http://app:8080/api/webhooks/channel-message
TELEGRAM_GATEWAY_CORE_WEBHOOK_TOKEN=
TELEGRAM_GATEWAY_TDJSON_LIB_PATH=/usr/local/lib/libtdjson.so
TELEGRAM_GATEWAY_TDLIB_DB_DIR=/data/tdlib
TELEGRAM_GATEWAY_TDLIB_FILES_DIR=/data/files
TELEGRAM_GATEWAY_LOG_LEVEL=INFO
